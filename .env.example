BACKEND_ACCESS_ID=
BACKEND_ACCESS_TOKEN=
BACKEND_TK=

# Username -> userId lookup (discovered from admin panel Network capture).
# Defaults are baked into the code; override here only if they change.
USER_LOOKUP_MODULE=/users/getAllUsers
USER_LOOKUP_USERNAME_FIELD=id

# Shared secret REQUIRED on every request via the `x-api-secret` header.
# The API is deny-by-default: if this is empty/unset, ALL requests get 401.
# Set it in production so only callers with the matching value can use the API.
PUBLIC_API_SECRET=

# Allowed browser origin(s). Leave EMPTY to default to:
#   https://99mykad.net, https://www.99mykad.net
# Or set a comma-separated list, or "*" to allow any origin.
ALLOWED_ORIGIN=
