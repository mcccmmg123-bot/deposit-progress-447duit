BACKEND_ACCESS_ID=
BACKEND_ACCESS_TOKEN=
BACKEND_TK=

# Username -> userId lookup (discovered from admin panel Network capture).
# Defaults are baked into the code; override here only if they change.
USER_LOOKUP_MODULE=/users/getAllUsers
USER_LOOKUP_USERNAME_FIELD=id

# Shared secret required on requests via the `x-api-secret` header.
# If left EMPTY, the check is DISABLED (any caller allowed). Set it in
# production so only your embed (with the matching value) can call the API.
PUBLIC_API_SECRET=

# CORS: which website origin may call this API from the browser.
# Use "*" to allow any origin, or set your site, e.g. https://www.example.com
ALLOWED_ORIGIN=*
